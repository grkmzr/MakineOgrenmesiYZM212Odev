# %% [markdown]
# ### 1. Teorik Kısım: Viterbi Algoritması

# %%
import numpy as np

# Viterbi algoritması manuel hesaplama
# Adım 1: t=1, gözlem High (0)
# e durumu: log(1.0) + log(0.7) = log(0.7)
# v durumu: 0 (imkansız, başlangıç e'de)

# Adım 2: t=2, gözlem Low (1)
# e'ye gelme: max(e->e: 0.6 * 0.3, v->e: 0.2 * 0.3) * önceki olasılık
# v'ye gelme: max(e->v: 0.4 * 0.9, v->v: 0.8 * 0.9) * önceki olasılık

# Sonuç: e-v dizisi daha olası
print("Viterbi sonucu: En olası fonem dizisi 'e-v'")

# %% [markdown]
# ### 2. Uygulama Kısmı: Python ile HMM Modelleri

# %%
from hmmlearn import hmm
import numpy as np

# %% EV kelimesi için model
model_ev = hmm.MultinomialHMM(n_components=2)
model_ev.startprob_ = np.array([1.0, 0.0])  # Başlangıç e'de
model_ev.transmat_ = np.array([[0.6, 0.4],
                                [0.2, 0.8]])
model_ev.emissionprob_ = np.array([[0.7, 0.3],
                                    [0.1, 0.9]])

# %% OKUL kelimesi için model
model_okul = hmm.MultinomialHMM(n_components=2)
model_okul.startprob_ = np.array([1.0, 0.0])  # Örnek olarak o-k gibi düşünelim
model_okul.transmat_ = np.array([[0.8, 0.2],
                                  [0.3, 0.7]])  # Rastgele geçişler
model_okul.emissionprob_ = np.array([[0.6, 0.4],
                                      [0.2, 0.8]])  # Rastgele emisyonlar

# %% Eğitim verisi (temsili)
# EV için örnek eğitim verisi (High=0, Low=1)
X_ev = np.array([[0, 0, 1, 1, 0, 0, 1]]).T  # Kolon vektörü
lengths_ev = [len(X_ev)]

# OKUL için örnek eğitim verisi
X_okul = np.array([[0, 1, 0, 1, 1, 0, 1]]).T
lengths_okul = [len(X_okul)]

# Modelleri eğit (aslında manuel verdik ama fit ile de yapılabilir)
model_ev.fit(X_ev, lengths_ev)
model_okul.fit(X_okul, lengths_okul)

# %% Test verisi (yeni bir ses kaydı)
test_data = np.array([[0, 1, 1]]).T  # High, Low, Low

# Log-olasılık hesapla
score_ev = model_ev.score(test_data)
score_okul = model_okul.score(test_data)

print(f"EV Modeli Puanı: {score_ev}")
print(f"OKUL Modeli Puanı: {score_okul}")

if score_ev > score_okul:
    print("Sonuç: Bu ses EV kelimesine ait.")
else:
    print("Sonuç: Bu ses OKUL kelimesine ait.")

